# Copy this file to .env.local and fill in the values.
# In Vercel, add the same variables under Project → Settings → Environment Variables.

# ── Supabase ────────────────────────────────────────────────────────
# Project URL (public). This is the CzechHub project.
NEXT_PUBLIC_SUPABASE_URL=https://copmxzljjuqahcylwhap.supabase.co

# Anon / publishable key (public — safe in the browser, read-only via RLS).
# Supabase Dashboard → Project Settings → API → "anon public" (or a publishable key).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SECRET — server only, never exposed to the browser).
# Supabase Dashboard → Project Settings → API → "service_role". Keep this private.
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin panel ─────────────────────────────────────────────────────
# Password that unlocks /admin and authorizes edits. Checked on the server.
# Defaults to "czechhub2026" if unset.
ADMIN_PASSWORD=
